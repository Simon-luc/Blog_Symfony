{% extends 'base.html.twig' %}

{% block title %}Article index
{% endblock %}

{% block body %}
	<h1>Article index</h1>

	<table class="table">
		<thead>
			<tr>
				<th>Id</th>
				<th>Title</th>
				<th>Content</th>
				<th>Image</th>
				<th>Actions</th>
			</tr>
		</thead>

		<tbody>
			{% for article in articles %}
				<tr>
				{#Le nombre d'article affichier dans ma bd dauto incrementation
				augmente sans alter table 
				
					<td>{{ article.id }}</td>#}

					<td>{{ loop.index }}</td>
					<td>{{ article.title }}</td>
					<td>{{ article.content }}</td>

					<td>
						{% if article.image %}
							<img src="{{ asset('uploads/images/' ~ article.image) }}" width="100">
						{% else %}
							<em>Aucune image</em>
						{% endif %}
					</td>

					<td>
						<a href="{{ path('app_article_show', {'id': article.id}) }}">show</a>
						<a href="{{ path('app_article_edit', {'id': article.id}) }}">edit</a>
					</td>
				</tr>
			{% else %}
				<tr>
					<td colspan="5">no records found</td>
				</tr>
			{% endfor %}
		</tbody>
	</table>

	<a href="{{ path('app_article_new') }}">Create new Article</a>

	{% if app.user %}
		<br>
		<a href="{{ path('app_logout') }}">Déconnexion</a>
	{% endif %}
{% endblock %}
